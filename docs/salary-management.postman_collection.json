{
  "info": {
    "name": "Salary Management API",
    "description": "CRUD and filtering endpoints for the Salary Management backend (http://localhost:8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "employeeId",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the Create Employee request."
    }
  ],
  "item": [
    {
      "name": "Employees",
      "item": [
        {
          "name": "List Employees (default pagination)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "List Employees (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List Employees (filter by country)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees?country=IN&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "country", "value": "IN" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List Employees (filter by department)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees?department=Engineering&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "department", "value": "Engineering" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List Employees (filter by country + department)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees?country=US&department=Engineering&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "country", "value": "US" },
                { "key": "department", "value": "Engineering" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Create Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('employeeId', json.id);",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has id', () => pm.expect(json.id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Aakruti Saxena\",\n  \"jobTitle\": \"Software Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 80000,\n  \"currency\": \"INR\",\n  \"email\": \"aakruti.saxena@example.com\",\n  \"department\": \"Engineering\",\n  \"hireDate\": \"2023-06-01\"\n}"
            }
          }
        },
        {
          "name": "Get Employee by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('employeeId')));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        },
        {
          "name": "Update Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Job title updated', () => pm.expect(pm.response.json().jobTitle).to.eql('Senior Software Engineer'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Aakruti Saxena\",\n  \"jobTitle\": \"Senior Software Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 95000,\n  \"currency\": \"INR\",\n  \"email\": \"aakruti.saxena@example.com\",\n  \"department\": \"Engineering\",\n  \"hireDate\": \"2023-06-01\"\n}"
            }
          }
        },
        {
          "name": "Delete Employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has message', () => pm.expect(pm.response.json().message).to.eql('Employee deleted successfully'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Insights",
      "item": [
        {
          "name": "Get Salary Insights",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has totalEmployees', () => pm.expect(pm.response.json().totalEmployees).to.be.a('number'));",
                  "pm.test('Has averageSalary', () => pm.expect(pm.response.json().averageSalary).to.be.a('number'));",
                  "pm.test('Has byDepartment array', () => pm.expect(pm.response.json().byDepartment).to.be.an('array'));",
                  "pm.test('Has byCountry array', () => pm.expect(pm.response.json().byCountry).to.be.an('array'));",
                  "pm.test('Department has expected fields', () => {",
                  "  const dept = pm.response.json().byDepartment[0];",
                  "  pm.expect(dept).to.have.all.keys('department', 'headcount', 'averageSalary', 'minSalary', 'maxSalary');",
                  "});",
                  "pm.test('Country has expected fields', () => {",
                  "  const country = pm.response.json().byCountry[0];",
                  "  pm.expect(country).to.have.all.keys('country', 'headcount', 'averageSalary', 'minSalary', 'maxSalary');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/insights",
              "host": ["{{baseUrl}}"],
              "path": ["api", "insights"]
            }
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Get Non-Existent Employee (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('Content-Type is problem+json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/employees/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
        {
          "name": "Create Employee - blank name (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Content-Type is problem+json', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"\",\n  \"jobTitle\": \"Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 75000,\n  \"currency\": \"INR\",\n  \"email\": \"test@example.com\",\n  \"department\": \"Engineering\",\n  \"hireDate\": \"2024-01-01\"\n}"
            }
          }
        },
        {
          "name": "Create Employee - invalid email (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"jobTitle\": \"Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 75000,\n  \"currency\": \"INR\",\n  \"email\": \"not-an-email\",\n  \"department\": \"Engineering\",\n  \"hireDate\": \"2024-01-01\"\n}"
            }
          }
        },
        {
          "name": "Create Employee - future hire date (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"jobTitle\": \"Engineer\",\n  \"country\": \"IN\",\n  \"salary\": 75000,\n  \"currency\": \"INR\",\n  \"email\": \"jane@example.com\",\n  \"department\": \"Engineering\",\n  \"hireDate\": \"2099-01-01\"\n}"
            }
          }
        },
        {
          "name": "Delete Non-Existent Employee (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/employees/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    }
  ]
}
